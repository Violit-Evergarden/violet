page {
  background: #0f172a;
  color: #e2e8f0;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

.container {
  padding: 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.card {
  background: rgba(15, 23, 42, 0.85);
  border: 1rpx solid #334155;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #94a3b8;
  margin-bottom: 24rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  color: #cbd5e1;
  margin-bottom: 16rpx;
}

.textarea {
  width: 100%;
  min-height: 220rpx;
  padding: 24rpx;
  box-sizing: border-box;
  background: #020617;
  border: 1rpx solid #475569;
  border-radius: 16rpx;
  color: #f1f5f9;
  font-size: 28rpx;
}

.btn-row {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.btn-secondary {
  flex: 1;
  background: #1e293b;
  color: #e2e8f0;
  border: 1rpx solid #475569;
  border-radius: 16rpx;
  font-size: 28rpx;
}

.btn-primary {
  flex: 2;
  background: #0ea5e9;
  color: #fff;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.btn-primary[disabled] {
  background: #475569;
  color: #94a3b8;
}

.alert {
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  font-size: 26rpx;
}

.alert-error {
  background: rgba(127, 29, 29, 0.35);
  border: 1rpx solid rgba(239, 68, 68, 0.4);
  color: #fecaca;
}

.alert-warning {
  background: rgba(120, 53, 15, 0.35);
  border: 1rpx solid rgba(245, 158, 11, 0.35);
  color: #fde68a;
}

.alert-info {
  background: rgba(12, 74, 110, 0.35);
  border: 1rpx solid rgba(14, 165, 233, 0.35);
  color: #bae6fd;
}

.result-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.result-meta {
  font-size: 24rpx;
  color: #94a3b8;
  margin-bottom: 20rpx;
}

.transcript {
  max-height: 600rpx;
  overflow-y: auto;
  background: #020617;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #e2e8f0;
  white-space: pre-wrap;
  word-break: break-all;
}

.copy-btn {
  margin-top: 20rpx;
  background: transparent;
  color: #38bdf8;
  border: 1rpx solid #475569;
  border-radius: 12rpx;
  font-size: 26rpx;
}
